#:kivy 1.0.9

<ChannelData>:
    canvas.before:
        Color:
            rgba: self.in_color
        Rectangle:
            pos: self.x + self.width * .1, self.y
            size: self.width/3*0.8, self.height*self.in_percent
        Color:
            rgba: self.out_color
        Rectangle:
            pos: self.x + self.width * .1 + self.width * 1/3, self.y
            size: self.width/3*0.8, self.height*self.out_percent
        Color:
            rgba: self.post_color
        Rectangle:
            pos: self.x + self.width * .1 + self.width*2/3, self.y
            size: self.width/3*0.8, self.height*self.post_percent
    orientation: "horizontal"
    BoxLayout:
        orientation: "vertical"
        Label:
            text: "2"
        Label:
            text: "7"
        Label:
            text: "12"
        Label:
            text: "17"
        Label:
            text: "22"
        Label:
            text: "27"
        Label:
            text: "32"
#   f"{self.ch_num} {self.gain} {self.ratio[0]} {self.thr[0]} {self.mgain[0]}"
#   f"{self.ch_name} {self.color} {self.ratio[1]} {self.thr[1]} {self.mgain[1]}"
    BoxLayout:
        orientation: "vertical"
        Label:
            text: self.parent.parent.mgain
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
        Label:
            text: self.parent.parent.gain
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
        Label:
            text: self.parent.parent.in_text
            color: self.parent.parent.color
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
        Label:
            text: self.parent.parent.level
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
    BoxLayout:
        orientation: "vertical"
        Label:
            text: self.parent.parent.ratio
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
        Label:
            text: self.parent.parent.thr
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
        Label:
            text: self.parent.parent.out_text
            color: self.parent.parent.color
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix
        Label:
            text: self.parent.parent.level_out
            canvas.before:
                PushMatrix
                Rotate:
                    angle: 90
                    origin: self.center
            canvas.after:
                PopMatrix

<XRemGUI>:
    channels: channels
    buses: buses
    xair_button: xair_button

    BoxLayout:
        orientation: "horizontal"
        size: root.width, root.height
        GridLayout:
            id: channels
            cols: 8
        BoxLayout:
            orientation: "vertical"
            size_hint_x: .7
            GridLayout:
                cols: 2
#                orientation: "horizontal"
                size_hint_y: .3
                Button:
                    text: "Connect XAir"
                    id: xair_button
#                    on_press: root.connect_mixer(self.state)
                    on_press: root.connect_mixer(True)
#                Button:
#                    text: "Record"
#                    on_state: root.record(self.state)
#                    on_press: root.record(True)
                Button:
                    text: "Quit"
                    on_press: root.quit() 
                    on_release: root.quit()
                Button:
                    text: "Disconnect XAir"
                    on_press: root.connect_mixer(False)
#                Button:
#                    text: "Stop"
#                    on_press: root.record(False)
                Button:
                    text: "Quit"
                    on_press: root.quit() 
                    on_release: root.quit()
            BoxLayout:
                orientation: "horizontal"
                id: buses